<?xml version="1.0" encoding="UTF-8" ?>
<schema name="minimal" version="1.7">
    <field name="id" type="string" indexed="true" stored="true" required="true" multiValued="false"/>
    <field name="class_name" type="string" indexed="true" stored="true"/>
    <field name="project" type="string" indexed="true" stored="true"/>
    <field name="class_version" type="pint" indexed="true" stored="true"/>
    <!-- Each entry: "constantValue|USAGE_TYPE" (e.g. "SELECT * FROM users|METHOD_INVOCATION_PARAMETER") -->
    <field name="constant_pairs_ss" type="string" indexed="true" stored="true" multiValued="true"/>
    <!-- Full-text searchable constant values (tokenised, lowercase, stored for highlighting) -->
    <field name="constant_values_t" type="text_general" indexed="true" stored="true" multiValued="true"/>
    <!-- Edge n-gram shadow copy for prefix / partial-word matching -->
    <field name="constant_values_ngram" type="text_edge_ngram" indexed="true" stored="false" multiValued="true"/>

    <!-- constant_values_t → ngram index at write time -->
    <copyField source="constant_values_t" dest="constant_values_ngram"/>

    <uniqueKey>id</uniqueKey>
    <fieldType name="string" class="solr.StrField" sortMissingLast="true" omitNorms="true"/>
    <fieldType name="boolean" class="solr.BoolField" sortMissingLast="true"/>
    <fieldType name="pint" class="solr.IntPointField" docValues="true"/>
    <fieldType name="pfloat" class="solr.FloatPointField" docValues="true"/>
    <!-- Standard tokenised full-text search (used by constant_values_t) -->
    <fieldType name="text_general" class="solr.TextField" positionIncrementGap="100">
        <analyzer type="index">
            <tokenizer class="solr.StandardTokenizerFactory"/>
            <filter class="solr.LowerCaseFilterFactory"/>
        </analyzer>
        <analyzer type="query">
            <tokenizer class="solr.StandardTokenizerFactory"/>
            <filter class="solr.LowerCaseFilterFactory"/>
        </analyzer>
    </fieldType>
    <!--
        Edge n-gram type: index-time expands every token into leading substrings
        (min=2 → "se", "sel", "sele", … "select") enabling prefix / autocomplete queries.
        Query-time uses plain tokens so scores stay meaningful.
    -->
    <fieldType name="text_edge_ngram" class="solr.TextField" positionIncrementGap="100">
        <analyzer type="index">
            <tokenizer class="solr.StandardTokenizerFactory"/>
            <filter class="solr.LowerCaseFilterFactory"/>
            <filter class="solr.EdgeNGramFilterFactory" minGramSize="2" maxGramSize="20"/>
        </analyzer>
        <analyzer type="query">
            <tokenizer class="solr.StandardTokenizerFactory"/>
            <filter class="solr.LowerCaseFilterFactory"/>
        </analyzer>
    </fieldType>
</schema>
